generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Sistema de Autenticação e Usuários ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      MarketplaceAccount[]
}

enum Role {
  ADMIN
  USER
}

// --- Gestão de Produtos e Estoque Central ---
model Product {
  id          String    @id @default(cuid())
  sku         String    @unique // SKU único como identificador central
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0) // Estoque central (Fonte da Verdade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // --- Campos de Autopeças (todos opcionais) ---
  costPrice       Decimal?       @db.Decimal(10, 2) // Preço de custo
  markup          Decimal?       @db.Decimal(10, 2)  // Margem de lucro (%)
  brand           String?        // Marca da peça
  model           String?        // Modelo do veículo
  year            String?        // Ano compatível (ex: "2018-2022")
  version         String?        // Versão do veículo
  category        String?        // Categoria da peça
  location        String?        // Localização no estoque
  partNumber      String?        // Part Number (OEM)
  quality         Quality?       // Qualidade da peça
  isSecurityItem  Boolean        @default(false) // Item de segurança
  isTraceable     Boolean        @default(false) // Item rastreável
  sourceVehicle   String?        // Veículo de origem (para sucata)

  // Relações
  listings    ProductListing[]
  stockLogs   StockLog[]
  orderItems  OrderItem[]
}

enum Quality {
  SUCATA      // Peça de desmanche
  SEMINOVO    // Usado em bom estado
  NOVO        // Peça nova/original
  RECONDICIONADO // Recondicionado/refurbished
}

// --- Integração com Marketplaces ---
model MarketplaceAccount {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  platform        Platform
  accountName     String
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  externalUserId  String?
  status          AccountStatus   @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  listings        ProductListing[]
  orders          Order[]
  syncLogs        SyncLog[]
}

enum Platform {
  MERCADO_LIVRE
  SHOPEE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

model ProductListing {
  id                   String             @id @default(cuid())
  productId            String
  product              Product            @relation(fields: [productId], references: [id])
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  externalListingId    String
  externalSku          String?
  status               String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  @@unique([marketplaceAccountId, externalListingId])
}

// --- Gestão de Pedidos ---
model Order {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  externalOrderId      String             @unique
  status               OrderStatus        @default(PENDING)
  totalAmount          Decimal            @db.Decimal(10, 2)
  customerName         String?
  customerEmail        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  items                OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
}

// --- Monitoramento e Logs ---
model StockLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  change      Int
  reason      String
  previousStock Int
  newStock    Int
  createdAt   DateTime @default(now())
}

model SyncLog {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)
  type                 SyncType
  status               SyncStatus
  message              String?
  payload              Json?
  createdAt            DateTime           @default(now())
}

enum SyncType {
  STOCK_UPDATE
  ORDER_IMPORT
  AUTH_REFRESH
  PRODUCT_SYNC
}

enum SyncStatus {
  SUCCESS
  FAILURE
  WARNING
}

