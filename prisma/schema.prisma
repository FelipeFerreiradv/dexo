generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String               @id @default(cuid())
  name                      String?
  email                     String               @unique
  password                  String
  avatarUrl                 String?
  role                      Role                 @default(USER)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  defaultProductDescription String?
  defaultCostPrice          Decimal?             @db.Decimal(10, 2)

  // Padrões de anúncio ML (preferências do usuário)
  defaultListingType        String?              // "bronze" | "gold_special" | "gold_pro"
  defaultHasWarranty        Boolean?             @default(false)
  defaultWarrantyUnit       String?              // "dias" | "meses"
  defaultWarrantyDuration   Int?
  defaultItemCondition      String?              // "new" | "used"
  defaultShippingMode       String?              // "me2" | "me1" | "custom" | "not_specified"
  defaultFreeShipping       Boolean?             @default(false)
  defaultLocalPickup        Boolean?             @default(false)
  defaultManufacturingTime  Int?                 @default(0)

  accounts                  MarketplaceAccount[]
  products                  Product[]
  systemLogs                SystemLog[]
  locations                 Location[]
  scraps                    Scrap[]
  customers                 Customer[]
  payables                  Payable[]
  receivables               Receivable[]
}

model Product {
  id                     String               @id @default(cuid())
  sku                    String
  skuNormalized          String?
  name                   String
  description            String?
  price                  Decimal              @db.Decimal(10, 2)
  stock                  Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  costPrice              Decimal?             @db.Decimal(10, 2)
  markup                 Decimal?             @db.Decimal(10, 2)
  brand                  String?
  model                  String?
  year                   String?
  version                String?
  category               String?
  location               String?
  partNumber             String?
  quality                Quality?
  isSecurityItem         Boolean              @default(false)
  isTraceable            Boolean              @default(false)
  sourceVehicle          String?
  imageUrl               String?
  imageUrls              String[]             @default([])
  mlCategoryId           String?
  heightCm               Int?
  lengthCm               Int?
  weightKg               Decimal?             @db.Decimal(6, 2)
  widthCm                Int?
  userId                 String?
  mlCategorySource       String?
  mlCategoryChosenAt     DateTime?
  shopeeCategoryId       String?
  shopeeCategorySource   String?
  shopeeCategoryChosenAt DateTime?
  locationId             String?
  scrapId                String?
  orderItems             OrderItem[]
  compatibilities        ProductCompatibility[]
  mlCategory             MarketplaceCategory? @relation("ProductMlCategory", fields: [mlCategoryId], references: [id])
  user                   User?                @relation(fields: [userId], references: [id])
  productLocation        Location?            @relation(fields: [locationId], references: [id])
  scrap                  Scrap?               @relation(fields: [scrapId], references: [id], onDelete: SetNull)
  listings               ProductListing[]
  stockLogs              StockLog[]

  @@unique([userId, sku])
  @@index([userId, skuNormalized])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([sku])
  @@index([locationId])
  @@index([scrapId])
}

model ProductCompatibility {
  id        String   @id @default(cuid())
  productId String
  brand     String
  model     String
  yearFrom  Int?
  yearTo    Int?
  version   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Location {
  id          String     @id @default(cuid())
  userId      String
  code        String
  description String?
  maxCapacity Int        @default(0)
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  parent      Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")
  products    Product[]
  scraps      Scrap[]

  @@unique([userId, code])
  @@index([userId])
  @@index([parentId])
}

model MarketplaceAccount {
  id             String           @id @default(cuid())
  userId         String
  platform       Platform
  accountName    String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  externalUserId String?
  status         AccountStatus    @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  shopId         Int?
  user           User             @relation(fields: [userId], references: [id])
  orders         Order[]
  listings       ProductListing[]
  syncLogs       SyncLog[]

  @@unique([platform, externalUserId])
  @@unique([platform, shopId])
  @@index([userId])
}

model ProductListing {
  id                   String             @id @default(cuid())
  productId            String
  marketplaceAccountId String
  externalListingId    String
  externalSku          String?
  status               String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  permalink            String?
  lastError            String?
  nextRetryAt          DateTime?
  retryAttempts        Int                @default(0)
  retryEnabled         Boolean            @default(false)
  requestedCategoryId  String?
  metricsUpdatedAt     DateTime?
  ratingAverage        Decimal?           @db.Decimal(3, 2)
  reviewsCount         Int                @default(0)
  viewsCount           Int                @default(0)
  orderItems           OrderItem[]
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  product              Product            @relation(fields: [productId], references: [id])

  @@unique([marketplaceAccountId, externalListingId])
  @@index([marketplaceAccountId, metricsUpdatedAt])
  @@index([productId])
}

model MarketplaceCategory {
  id               String          @id @default(cuid())
  externalId       String          @unique
  siteId           String
  name             String
  fullPath         String
  pathFromRoot     Json
  parentExternalId String?
  keywords         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  aliases          CategoryAlias[]
  products         Product[]       @relation("ProductMlCategory")

  @@index([siteId])
  @@index([parentExternalId])
}

model CategoryAlias {
  id                    String              @id @default(cuid())
  marketplaceCategoryId String
  tokens                String?
  synonyms              String?
  brandModelPatterns    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  marketplaceCategory   MarketplaceCategory @relation(fields: [marketplaceCategoryId], references: [id])

  @@index([marketplaceCategoryId])
}

model Order {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  externalOrderId      String
  status               OrderStatus        @default(PENDING)
  totalAmount          Decimal            @db.Decimal(10, 2)
  customerName         String?
  customerEmail        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  items                OrderItem[]

  @@index([marketplaceAccountId, createdAt])
  @@index([status, updatedAt])
  @@unique([marketplaceAccountId, externalOrderId])
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
  listingId String?
  listing   ProductListing? @relation(fields: [listingId], references: [id])
  order     Order           @relation(fields: [orderId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])

  @@index([listingId])
  @@index([orderId])
  @@index([productId])
}

model StockLog {
  id            String   @id @default(cuid())
  productId     String
  change        Int
  reason        String
  previousStock Int
  newStock      Int
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([productId, createdAt])
}

model StockSyncJob {
  id           String   @id @default(cuid())
  productId    String
  listingId    String
  platform     Platform
  targetStock  Int
  attempts     Int      @default(0)
  nextRunAt    DateTime @default(now())
  status       String   @default("PENDING")
  lastError    String?
  orderId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([listingId, status])
  @@index([status, nextRunAt])
  @@index([productId])
}

model MLCategoryAttributeCache {
  categoryId    String   @id
  attributes    Json
  fetchedAt     DateTime @default(now())
  ttlExpiresAt  DateTime

  @@index([ttlExpiresAt])
}

model WebhookEventLog {
  id          String   @id @default(cuid())
  source      String
  externalId  String
  payload     Json?
  createdAt   DateTime @default(now())

  @@unique([source, externalId])
  @@index([createdAt])
}

model SyncLog {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  type                 SyncType
  status               SyncStatus
  message              String?
  payload              Json?
  createdAt            DateTime           @default(now())
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)

  @@index([marketplaceAccountId])
}

model SystemLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  level      LogLevel
  message    String
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  USER
}

enum Quality {
  SUCATA
  SEMINOVO
  NOVO
  RECONDICIONADO
}

enum Platform {
  MERCADO_LIVRE
  SHOPEE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SyncType {
  STOCK_UPDATE
  ORDER_IMPORT
  AUTH_REFRESH
  PRODUCT_SYNC
}

enum SyncStatus {
  SUCCESS
  FAILURE
  WARNING
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum ScrapStatus {
  AVAILABLE
  IN_USE
  DEPLETED
  ARCHIVED
}

enum FinanceStatus {
  PENDENTE
  PAGA
  VENCIDA
  CANCELADA
}

model Customer {
  id             String    @id @default(cuid())
  userId         String

  // Identificação PF
  name           String
  cpf            String?
  rg             String?
  birthDate      DateTime?
  gender         String?
  maritalStatus  String?
  email          String?
  phone          String?
  mobile         String?

  // Endereço principal
  cep            String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  ibge           String?
  reference      String?

  // Dados adicionais / entrega (PJ ou 2º endereço)
  deliveryName          String?
  deliveryCorporateName String?
  deliveryCpf           String?
  deliveryCnpj          String?
  deliveryRg            String?
  deliveryCep           String?
  deliveryPhone         String?
  deliveryCity          String?
  deliveryNeighborhood  String?
  deliveryState         String?
  deliveryStreet        String?
  deliveryComplement    String?
  deliveryNumber        String?

  notes          String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User         @relation(fields: [userId], references: [id])
  payables       Payable[]
  receivables    Receivable[]

  @@unique([userId, cpf])
  @@index([userId, createdAt])
  @@index([userId, name])
}

model Receivable {
  id              String        @id @default(cuid())
  userId          String
  customerId      String

  document        String?
  reason          String?
  debtDetails     String?
  totalAmount     Decimal       @db.Decimal(12, 2)

  fineAmount      Decimal?      @db.Decimal(12, 2)
  finePercent     Decimal?      @db.Decimal(5, 2)
  interestPercent Decimal?      @db.Decimal(5, 2)
  toleranceDays   Int?

  installments    Int           @default(1)
  periodDays      Int?
  dueDate         DateTime

  status          FinanceStatus @default(PENDENTE)
  paidAt          DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([customerId])
}

// Nota de negócio: Payable também referencia Customer por regra explícita do usuário.
model Payable {
  id              String        @id @default(cuid())
  userId          String
  customerId      String

  document        String?
  reason          String?
  debtDetails     String?
  totalAmount     Decimal       @db.Decimal(12, 2)

  fineAmount      Decimal?      @db.Decimal(12, 2)
  finePercent     Decimal?      @db.Decimal(5, 2)
  interestPercent Decimal?      @db.Decimal(5, 2)
  toleranceDays   Int?

  installments    Int           @default(1)
  periodDays      Int?
  dueDate         DateTime

  status          FinanceStatus @default(PENDENTE)
  paidAt          DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([customerId])
}

model Scrap {
  id                 String      @id @default(cuid())
  userId             String

  // Dados do veículo
  brand              String
  model              String
  year               String?
  version            String?
  color              String?
  plate              String?
  chassis            String?
  engineNumber       String?
  renavam            String?
  lot                String?
  deregistrationCert String?

  // Custo e pagamento
  cost               Decimal?    @db.Decimal(10, 2)
  paymentMethod      String?

  // Localização (referência à entidade Location existente)
  locationId         String?
  location           Location?   @relation(fields: [locationId], references: [id])

  // Dados fiscais / NF-e
  ncm                String?
  supplierCnpj       String?
  accessKey          String?
  issueDate          DateTime?
  entryDate          DateTime?
  nfeNumber          String?
  nfeProtocol        String?
  operationNature    String?
  nfeSeries          String?
  fiscalModel        String?
  icmsValue          Decimal?    @db.Decimal(10, 2)
  icmsCtValue        Decimal?    @db.Decimal(10, 2)
  freightMode        String?
  issuePurpose       String?

  // Imagens/Anexos
  imageUrls          String[]    @default([])

  // Status e controle
  status             ScrapStatus @default(AVAILABLE)
  notes              String?

  // Timestamps
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relacionamentos
  user               User        @relation(fields: [userId], references: [id])
  products           Product[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([plate])
  @@index([chassis])
}
