generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String               @id @default(cuid())
  name                      String?
  email                     String               @unique
  password                  String
  avatarUrl                 String?
  role                      Role                 @default(USER)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  defaultProductDescription String?
  accounts                  MarketplaceAccount[]
  products                  Product[]
  systemLogs                SystemLog[]
}

model Product {
  id                     String               @id @default(cuid())
  sku                    String               @unique
  name                   String
  description            String?
  price                  Decimal              @db.Decimal(10, 2)
  stock                  Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  costPrice              Decimal?             @db.Decimal(10, 2)
  markup                 Decimal?             @db.Decimal(10, 2)
  brand                  String?
  model                  String?
  year                   String?
  version                String?
  category               String?
  location               String?
  partNumber             String?
  quality                Quality?
  isSecurityItem         Boolean              @default(false)
  isTraceable            Boolean              @default(false)
  sourceVehicle          String?
  imageUrl               String?
  mlCategoryId           String?
  heightCm               Int?
  lengthCm               Int?
  weightKg               Decimal?             @db.Decimal(6, 2)
  widthCm                Int?
  userId                 String?
  mlCategorySource       String?
  mlCategoryChosenAt     DateTime?
  shopeeCategoryId       String?
  shopeeCategorySource   String?
  shopeeCategoryChosenAt DateTime?
  orderItems             OrderItem[]
  mlCategory             MarketplaceCategory? @relation("ProductMlCategory", fields: [mlCategoryId], references: [id])
  user                   User?                @relation(fields: [userId], references: [id])
  listings               ProductListing[]
  stockLogs              StockLog[]

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
}

model MarketplaceAccount {
  id             String           @id @default(cuid())
  userId         String
  platform       Platform
  accountName    String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  externalUserId String?
  status         AccountStatus    @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  shopId         Int?
  user           User             @relation(fields: [userId], references: [id])
  orders         Order[]
  listings       ProductListing[]
  syncLogs       SyncLog[]

  @@index([userId])
}

model ProductListing {
  id                   String             @id @default(cuid())
  productId            String
  marketplaceAccountId String
  externalListingId    String
  externalSku          String?
  status               String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  permalink            String?
  lastError            String?
  nextRetryAt          DateTime?
  retryAttempts        Int                @default(0)
  retryEnabled         Boolean            @default(false)
  requestedCategoryId  String?
  metricsUpdatedAt     DateTime?
  ratingAverage        Decimal?           @db.Decimal(3, 2)
  reviewsCount         Int                @default(0)
  viewsCount           Int                @default(0)
  orderItems           OrderItem[]
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  product              Product            @relation(fields: [productId], references: [id])

  @@unique([marketplaceAccountId, externalListingId])
  @@index([marketplaceAccountId, metricsUpdatedAt])
}

model MarketplaceCategory {
  id               String          @id @default(cuid())
  externalId       String          @unique
  siteId           String
  name             String
  fullPath         String
  pathFromRoot     Json
  parentExternalId String?
  keywords         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  aliases          CategoryAlias[]
  products         Product[]       @relation("ProductMlCategory")

  @@index([siteId])
  @@index([parentExternalId])
}

model CategoryAlias {
  id                    String              @id @default(cuid())
  marketplaceCategoryId String
  tokens                String?
  synonyms              String?
  brandModelPatterns    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  marketplaceCategory   MarketplaceCategory @relation(fields: [marketplaceCategoryId], references: [id])

  @@index([marketplaceCategoryId])
}

model Order {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  externalOrderId      String             @unique
  status               OrderStatus        @default(PENDING)
  totalAmount          Decimal            @db.Decimal(10, 2)
  customerName         String?
  customerEmail        String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  items                OrderItem[]

  @@index([marketplaceAccountId, createdAt])
  @@index([status, updatedAt])
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
  listingId String?
  listing   ProductListing? @relation(fields: [listingId], references: [id])
  order     Order           @relation(fields: [orderId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])

  @@index([listingId])
}

model StockLog {
  id            String   @id @default(cuid())
  productId     String
  change        Int
  reason        String
  previousStock Int
  newStock      Int
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])
}

model SyncLog {
  id                   String             @id @default(cuid())
  marketplaceAccountId String
  type                 SyncType
  status               SyncStatus
  message              String?
  payload              Json?
  createdAt            DateTime           @default(now())
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  level      LogLevel
  message    String
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}

enum Quality {
  SUCATA
  SEMINOVO
  NOVO
  RECONDICIONADO
}

enum Platform {
  MERCADO_LIVRE
  SHOPEE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SyncType {
  STOCK_UPDATE
  ORDER_IMPORT
  AUTH_REFRESH
  PRODUCT_SYNC
}

enum SyncStatus {
  SUCCESS
  FAILURE
  WARNING
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}
